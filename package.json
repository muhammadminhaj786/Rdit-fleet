{
  "name": "redi-fleet",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "test:push-notification": "node scripts/test-send-push-notification.js",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "build:android:release": "cd android && .\\gradlew.bat assembleRelease",
    "build:android:bundle": "cd android && .\\gradlew.bat bundleRelease",
    "build:ios:release": "cd ios && xcodebuild -workspace reditfleet.xcworkspace -scheme reditfleet -configuration Release -archivePath build/reditfleet.xcarchive archive"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "^8.6.0",
    "@stripe/stripe-react-native": "0.50.3",
    "@supabase/supabase-js": "^2.87.1",
    "expo": "~54.0.26",
    "expo-constants": "~18.0.11",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.10",
    "expo-notifications": "~0.32.15",
    "expo-router": "~6.0.16",
    "expo-status-bar": "~3.0.8",
    "expo-text-recognition": "^0.1.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-country-codes-picker": "^2.3.5",
    "react-native-country-picker-modal": "^2.0.0",
    "react-native-international-phone-number": "^0.11.4",
    "react-native-paper": "^5.14.5",
    "react-native-phone-number-input": "^2.1.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
